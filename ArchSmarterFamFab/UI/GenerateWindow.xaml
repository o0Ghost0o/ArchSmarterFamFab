<Window x:Class="ArchSmarterFamFab.UI.GenerateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Family Fabricator"
        Width="520"
        Height="650"
        MinWidth="400"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6"
                      CornerRadius="8" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FamFabStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="#3f3f46"
            BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Background="#1e1e1e" CornerRadius="8,8,0,0"
                    Padding="16,10" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   Foreground="#e0e0e0" VerticalAlignment="Center">
                            <Run Text="Fam"/><Run Text="|" Foreground="#E8812A"/><Run Text="Fab"/>
                        </TextBlock>
                        <TextBlock Text="&#x00B7;" FontSize="13"
                                   Foreground="#3f3f46" VerticalAlignment="Center"
                                   Margin="10,0"/>
                        <TextBlock Text="Generate" FontSize="11"
                                   Foreground="#808080" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Click="BtnClose_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="closeBg" Background="Transparent"
                                        CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="&#x2715;" FontSize="11"
                                               Foreground="#808080"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="closeBg" Property="Background"
                                                Value="#3f3f46"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="32,24,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: header -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>  <!-- 2: image file -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>  <!-- 4: family name -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>  <!-- 6: context prompt -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>  <!-- 8: model -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>  <!-- 10: progress -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>  <!-- 12: buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="Select an image to generate a Revit family"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- Image File -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Image File" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource FamFabBorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="10,7">
                            <TextBlock x:Name="TxtFilePath"
                                       Text="No file selected"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button x:Name="BtnBrowse" Grid.Column="1" Content="Browse"
                                Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0"
                                Click="BtnBrowse_Click"/>
                    </Grid>
                    <!-- Image preview -->
                    <Border x:Name="PreviewBorder"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource FamFabBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="0,10,0,0"
                            Padding="8"
                            Visibility="Collapsed">
                        <Image x:Name="ImagePreview"
                               MaxHeight="160"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Family Name -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="Family Name (optional)" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtFamilyName"
                             MaxLength="100">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="e.g., Octagonal Chandelier"
                                                                   Foreground="#555555" FontSize="13"
                                                                   Margin="12,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>

                <!-- Additional Context -->
                <StackPanel Grid.Row="6">
                    <TextBlock Text="Additional Context (optional)" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtContext"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="60"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"/>
                </StackPanel>

                <!-- Model -->
                <StackPanel Grid.Row="8">
                    <TextBlock Text="Model" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbModel"/>
                </StackPanel>

                <!-- Progress area (hidden until generating) -->
                <StackPanel x:Name="ProgressPanel" Grid.Row="10" Visibility="Collapsed">
                    <ProgressBar IsIndeterminate="True"
                                 Height="4"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource AccentBrush}"
                                 BorderThickness="0"
                                 Margin="0,0,0,8"/>
                    <TextBlock x:Name="StatusLabel"
                               Text="Sending image to Claude API..."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Buttons -->
                <Grid Grid.Row="12">
                    <Button x:Name="BtnLoadJson" Content="Load JSON..."
                            Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left"
                            Click="BtnLoadJson_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnCancel" Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,0"
                                Click="BtnCancel_Click" IsDefault="False" IsCancel="True"/>
                        <Button x:Name="BtnGenerate" Content="Generate"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnGenerate_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
