<Window x:Class="ArchSmarterFamFab.UI.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Family Fabricator"
        Width="1200"
        Height="800"
        MinWidth="700"
        MinHeight="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6"
                      CornerRadius="8" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FamFabStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="#3f3f46"
            BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Background="#1e1e1e" CornerRadius="8,8,0,0"
                    Padding="16,10" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   Foreground="#e0e0e0" VerticalAlignment="Center">
                            <Run Text="Fam"/><Run Text="|" Foreground="#E8812A"/><Run Text="Fab"/>
                        </TextBlock>
                        <TextBlock Text="&#x00B7;" FontSize="13"
                                   Foreground="#3f3f46" VerticalAlignment="Center"
                                   Margin="10,0"/>
                        <TextBlock Text="Preview" FontSize="11"
                                   Foreground="#808080" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Click="BtnClose_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="closeBg" Background="Transparent"
                                        CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="&#x2715;" FontSize="11"
                                               Foreground="#808080"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="closeBg" Property="Background"
                                                Value="#3f3f46"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left panel: metadata + refine prompt -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource FamFabBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="16,16,16,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Metadata -->
                        <StackPanel Grid.Row="0">
                            <!-- Source image thumbnail -->
                            <Border x:Name="ImageBorder"
                                    Background="{StaticResource SurfaceLightBrush}"
                                    BorderBrush="{StaticResource FamFabBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,0,0,12"
                                    Padding="6"
                                    Cursor="Hand"
                                    Visibility="Collapsed"
                                    MouseLeftButtonUp="ImageBorder_MouseLeftButtonUp">
                                <Image x:Name="SourceImagePreview"
                                       MaxHeight="140"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Family Name -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Family Name" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                <TextBox x:Name="TxtFamilyName"
                                         MaxLength="100"
                                         FontSize="13"/>
                            </StackPanel>

                            <Expander IsExpanded="True" Margin="0,0,0,4">
                                <Expander.Header>
                                    <TextBlock Text="Family Details" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Expander.Header>
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Description" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="TxtDescription" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12" Margin="0,0,0,10"/>

                                    <TextBlock Text="Category" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="TxtCategory"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12" Margin="0,0,0,10"/>

                                    <TextBlock Text="Parameters" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="TxtParamCount"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12" Margin="0,0,0,10"/>

                                    <TextBlock Text="Geometry" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="TxtGeomCount"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Grid.Row="1" Height="1"
                                Background="{StaticResource FamFabBorderBrush}" Margin="0,12,0,12"/>

                        <!-- Refine prompt area -->
                        <DockPanel Grid.Row="2">
                            <TextBlock DockPanel.Dock="Top" Text="Refine with AI" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock DockPanel.Dock="Top" Text="Describe changes to make to this family."
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtPrompt"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"/>
                        </DockPanel>

                        <!-- Refine progress -->
                        <StackPanel x:Name="RefineProgress" Grid.Row="3" Visibility="Collapsed" Margin="0,8,0,0">
                            <ProgressBar IsIndeterminate="True" Height="4"
                                         Background="{StaticResource SurfaceBrush}"
                                         Foreground="{StaticResource AccentBrush}"
                                         BorderThickness="0"
                                         Margin="0,0,0,6"/>
                            <TextBlock x:Name="RefineStatusText" Text="Refining..." FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="4" Margin="0,12,0,0">
                            <Button x:Name="BtnRefine" Content="Refine"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnRefine_Click"/>
                            <Button x:Name="BtnGenerate" Content="Generate Family" Margin="0,8,0,0"
                                    Style="{StaticResource BrandButton}"
                                    Click="BtnGenerate_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right panel: 3D viewer -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <wv2:WebView2 x:Name="WebView" Grid.Row="0"/>

                    <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource FamFabBorderBrush}" BorderThickness="0,1,0,0"
                            Padding="16,8">
                        <TextBlock x:Name="StatusText"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
