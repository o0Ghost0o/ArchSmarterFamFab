<Window x:Class="ArchSmarterFamFab.UI.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FamFab - TripoSR Installer"
        Width="640"
        Height="520"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6"
                      CornerRadius="8" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FamFabStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="#3f3f46"
            BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Background="#1e1e1e" CornerRadius="8,8,0,0"
                    Padding="16,10" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   Foreground="#e0e0e0" VerticalAlignment="Center">
                            <Run Text="Fam"/><Run Text="|" Foreground="#E8812A"/><Run Text="Fab"/>
                        </TextBlock>
                        <TextBlock Text="&#x00B7;" FontSize="13"
                                   Foreground="#3f3f46" VerticalAlignment="Center"
                                   Margin="10,0"/>
                        <TextBlock Text="TripoSR Installer" FontSize="11"
                                   Foreground="#808080" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="BtnTitleClose" Click="BtnClose_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="closeBg" Background="Transparent"
                                        CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="&#x2715;" FontSize="11"
                                               Foreground="#808080"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="closeBg" Property="Background"
                                                Value="#3f3f46"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="32,24,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0"
                           x:Name="HeaderLabel"
                           Text="TripoSR dependencies are missing"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1"
                           x:Name="SubHeaderLabel"
                           Text="FamFab can download and install the required Python packages automatically. This may take several minutes."
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>

                <!-- Package list -->
                <TextBlock Grid.Row="3"
                           Text="Packages to install:"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13"/>
                <TextBlock Grid.Row="5"
                           x:Name="PackageList"
                           Text="torch, numpy, Pillow, xatlas, rembg, scikit-image, trimesh, einops, huggingface-hub, transformers, safetensors, omegaconf, moderngl, torchmcubes"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           LineHeight="18"
                           Margin="0,2,0,0"/>

                <!-- Progress + Log -->
                <Grid Grid.Row="7">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="ProgressBar"
                                  Grid.Row="0"
                                  IsIndeterminate="True"
                                  Height="4"
                                  Background="{StaticResource SurfaceBrush}"
                                  Foreground="{StaticResource AccentBrush}"
                                  BorderThickness="0"
                                  Visibility="Collapsed"/>

                    <Border Grid.Row="2"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource FamFabBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ScrollViewer x:Name="LogScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Margin="8">
                            <TextBlock x:Name="LogText"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Text="Ready to install."/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Error message -->
                <TextBlock Grid.Row="9"
                           x:Name="ErrorLabel"
                           Text=""
                           FontSize="12"
                           Foreground="#FF6B6B"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>

                <!-- Buttons -->
                <Grid Grid.Row="11">
                    <Button x:Name="BtnCancel"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left"
                            Click="BtnCancel_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnInstall"
                                Content="Install"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,10,0"
                                Click="BtnInstall_Click"/>
                        <Button x:Name="BtnContinue"
                                Content="Continue"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnContinue_Click"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
